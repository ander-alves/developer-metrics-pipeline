{
    "swagger": "2.0",
    "info": {
        "description": "Aggregated developer productivity metrics — commits, pull requests, review time.",
        "title": "Developer Metrics API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Returns 200 when the aggregator process is running",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ops"
                ],
                "summary": "Liveness probe",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/metrics/{developer_id}": {
            "get": {
                "description": "Returns every processed event stored for the given developer",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "List developer events",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Developer ID",
                        "name": "developer_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "developer_id is required",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "internal error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/metrics/{developer_id}/summary": {
            "get": {
                "description": "Returns aggregated totals (commits, PRs, review time) for the developer",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "Developer summary",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Developer ID",
                        "name": "developer_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.DeveloperSummary"
                        }
                    },
                    "400": {
                        "description": "developer_id is required",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "internal error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.DeveloperSummary": {
            "type": "object",
            "properties": {
                "avg_review_time_minutes": {
                    "type": "number"
                },
                "developer_id": {
                    "type": "string"
                },
                "events_processed": {
                    "type": "integer"
                },
                "last_activity": {
                    "type": "string"
                },
                "review_time_events_count": {
                    "type": "integer"
                },
                "total_commits": {
                    "type": "integer"
                },
                "total_pull_requests": {
                    "type": "integer"
                },
                "total_review_time_minutes": {
                    "type": "number"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        }
    }
}